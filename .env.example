# ─── Server ───────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3002
JWT_SECRET=change-me-to-a-random-secret-in-production

# ─── Database (Prisma) ────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── External APIs ────────────────────────────────────────────────────
FRED_API_KEY=your_fred_api_key_here

# Schwab API (OAuth2 PKCE)
SCHWAB_CLIENT_ID=your_schwab_client_id
SCHWAB_CLIENT_SECRET=your_schwab_client_secret
SCHWAB_CALLBACK_URL=https://127.0.0.1:3000
SCHWAB_TOKEN_PATH=./.schwab-token.json

# ─── Sentry Error Tracking ────────────────────────────────────────────
# Backend DSN (Node.js)
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=development

# Frontend DSN (Vite/React) — set in frontend .env or shell
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
VITE_SENTRY_ENVIRONMENT=development

# Sentry Auth Token (optional, for source map uploads during build)
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project
